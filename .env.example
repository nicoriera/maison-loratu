# Copiez ce fichier vers .env.local pour tester l’interface admin sans Netlify.
# Ce mode est limité à Vite DEV et ne contacte ni Identity ni l’API.
VITE_ADMIN_LOCAL_PREVIEW=false

# Optionnel : lien Resalib sécurisé injecté dans la configuration publique.
# Sans cette variable, les boutons « Réserver » ouvrent https://www.resalib.fr/.
# VITE_RESALIB_URL=https://www.resalib.fr/...
